# Supabase 設定（複製此檔案為 .env.local 並填入實際值）
# 實際的 URL 與 anon key 請至 Supabase Dashboard > Project Settings > API 取得
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# Google OAuth 設定說明
# 需在以下兩處設定 redirect URI：
# 1. Google Cloud Console > Credentials > OAuth 2.0 Client IDs
#    Authorized redirect URIs 加入：https://<your-project-ref>.supabase.co/auth/v1/callback
# 2. Supabase Dashboard > Authentication > URL Configuration
#    Site URL: http://localhost:5173（開發）或正式 URL
#    Redirect URLs: http://localhost:5173/auth/callback（開發）
